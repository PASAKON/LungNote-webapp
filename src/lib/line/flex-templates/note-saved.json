{
  "type": "flex",
  "altText": "บันทึกโน้ตเรียบร้อยแล้ว — LungNote",
  "contents": {
    "type": "bubble",
    "size": "giga",
    "header": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            {
              "type": "text",
              "text": "✓",
              "size": "3xl",
              "weight": "bold",
              "color": "#c9a040",
              "align": "center"
            }
          ],
          "width": "56px",
          "height": "56px",
          "backgroundColor": "#f0e4c4",
          "cornerRadius": "50px",
          "justifyContent": "center",
          "alignItems": "center",
          "offsetStart": "calc(50% - 28px)"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "SAVED",
              "size": "xxs",
              "color": "#c9a040",
              "weight": "bold"
            }
          ],
          "backgroundColor": "#f0e4c4",
          "cornerRadius": "sm",
          "paddingAll": "4px",
          "paddingStart": "8px",
          "paddingEnd": "8px",
          "width": "60px",
          "margin": "md",
          "offsetStart": "calc(50% - 30px)"
        },
        {
          "type": "text",
          "text": "บันทึกเรียบร้อยแล้ว!",
          "weight": "bold",
          "size": "xl",
          "margin": "md",
          "color": "#3a3020",
          "align": "center"
        },
        {
          "type": "text",
          "text": "โน้ตของคุณถูกบันทึกและ sync เรียบร้อยแล้ว",
          "size": "sm",
          "color": "#a08050",
          "wrap": true,
          "margin": "sm",
          "align": "center"
        }
      ],
      "paddingAll": "20px",
      "paddingTop": "24px"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "separator",
          "color": "#d4c4a0"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "ชื่อโน้ต",
              "size": "xs",
              "color": "#a08050",
              "flex": 3
            },
            {
              "type": "text",
              "text": "{{note_title}}",
              "size": "xs",
              "weight": "bold",
              "color": "#3a3020",
              "align": "end",
              "flex": 5,
              "wrap": true
            }
          ],
          "margin": "lg",
          "paddingBottom": "8px"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "โฟลเดอร์",
              "size": "xs",
              "color": "#a08050",
              "flex": 3
            },
            {
              "type": "text",
              "text": "{{folder_name}}",
              "size": "xs",
              "weight": "bold",
              "color": "#3a3020",
              "align": "end",
              "flex": 5
            }
          ],
          "paddingBottom": "8px"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "บันทึกเมื่อ",
              "size": "xs",
              "color": "#a08050",
              "flex": 3
            },
            {
              "type": "text",
              "text": "{{saved_at}}",
              "size": "xs",
              "weight": "bold",
              "color": "#3a3020",
              "align": "end",
              "flex": 5
            }
          ]
        }
      ],
      "paddingAll": "16px",
      "paddingTop": "8px"
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#c9a040",
          "action": {
            "type": "uri",
            "label": "เปิดดูโน้ต",
            "uri": "https://liff.line.me/YOUR_LIFF_ID/note/{{note_id}}"
          },
          "height": "md"
        },
        {
          "type": "button",
          "style": "link",
          "color": "#a08050",
          "action": {
            "type": "uri",
            "label": "กลับหน้า Dashboard",
            "uri": "https://liff.line.me/YOUR_LIFF_ID/dashboard"
          },
          "height": "sm"
        }
      ],
      "paddingAll": "16px"
    }
  }
}
