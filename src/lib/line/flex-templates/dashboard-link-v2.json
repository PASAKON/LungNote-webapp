{
  "type": "flex",
  "altText": "LungNote Dashboard — {{pending_count}} งานค้าง",
  "contents": {
    "type": "bubble",
    "size": "giga",
    "hero": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "text",
          "text": "LungNote Dashboard",
          "size": "lg",
          "weight": "bold",
          "color": "#ffffff",
          "align": "center"
        }
      ],
      "background": {
        "type": "linearGradient",
        "angle": "135deg",
        "startColor": "#c9a040",
        "endColor": "#d4a855"
      },
      "paddingAll": "24px",
      "justifyContent": "center",
      "alignItems": "center"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "box",
              "layout": "vertical",
              "contents": [
                { "type": "text", "text": "{{total_notes}}", "size": "xl", "weight": "bold", "color": "#c9a040", "align": "center" },
                { "type": "text", "text": "โน้ต", "size": "xxs", "color": "#a08050", "align": "center" }
              ],
              "flex": 1
            },
            { "type": "separator", "color": "#d4c4a0" },
            {
              "type": "box",
              "layout": "vertical",
              "contents": [
                { "type": "text", "text": "{{pending_count}}", "size": "xl", "weight": "bold", "color": "#e8a946", "align": "center" },
                { "type": "text", "text": "ค้าง", "size": "xxs", "color": "#a08050", "align": "center" }
              ],
              "flex": 1
            },
            { "type": "separator", "color": "#d4c4a0" },
            {
              "type": "box",
              "layout": "vertical",
              "contents": [
                { "type": "text", "text": "{{completed_count}}", "size": "xl", "weight": "bold", "color": "#7a9a50", "align": "center" },
                { "type": "text", "text": "เสร็จ", "size": "xxs", "color": "#a08050", "align": "center" }
              ],
              "flex": 1
            },
            { "type": "separator", "color": "#d4c4a0" },
            {
              "type": "box",
              "layout": "vertical",
              "contents": [
                { "type": "text", "text": "{{streak_days}}", "size": "xl", "weight": "bold", "color": "#3a3020", "align": "center" },
                { "type": "text", "text": "Streak", "size": "xxs", "color": "#a08050", "align": "center" }
              ],
              "flex": 1
            }
          ],
          "paddingAll": "12px"
        },
        { "type": "separator", "color": "#d4c4a0" },
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            {
              "type": "box",
