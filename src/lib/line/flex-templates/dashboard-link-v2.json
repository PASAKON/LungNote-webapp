              "contents": [
                { "type": "text", "text": "✓", "size": "sm", "color": "#c9a040", "flex": 0 },
                { "type": "text", "text": "{{recent_done_1}}", "size": "sm", "color": "#c4b490", "decoration": "line-through", "margin": "sm", "flex": 1 }
              ]
            },
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "☐", "size": "sm", "color": "#c9a040", "flex": 0 },
                { "type": "text", "text": "{{next_todo_1}}", "size": "sm", "color": "#3a3020", "margin": "sm", "flex": 1 },
                { "type": "text", "text": "{{next_todo_1_due}}", "size": "xxs", "color": "#e8a946", "align": "end", "flex": 0 }
              ],
              "margin": "sm"
            },
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "☐", "size": "sm", "color": "#c9a040", "flex": 0 },
                { "type": "text", "text": "{{next_todo_2}}", "size": "sm", "color": "#3a3020", "margin": "sm", "flex": 1 },
                { "type": "text", "text": "{{next_todo_2_due}}", "size": "xxs", "color": "#3a3020", "align": "end", "flex": 0 }
