{
  "type": "flex",
  "altText": "ลบ '{{text}}' แล้ว — เหลือ {{remaining_count}} รายการ",
  "contents": {
    "type": "bubble",
    "size": "kilo",
    "header": {
      "type": "box",
      "layout": "horizontal",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            { "type": "text", "text": "ลบสำเร็จ ❌", "weight": "bold", "size": "lg", "color": "#ffffff" },
            { "type": "text", "text": "รายการถูกลบเรียบร้อยแล้ว", "size": "xxs", "color": "#ffffff99", "margin": "sm" }
          ],
          "flex": 3
        }
      ],
      "paddingAll": "20px",
      "paddingBottom": "12px",
      "background": { "type": "linearGradient", "angle": "135deg", "startColor": "#c45a3a", "endColor": "#d06850" }
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "📁", "size": "xs", "flex": 0 },
                { "type": "text", "text": "{{folder_name}}", "size": "xxs", "color": "#c45a3a", "weight": "bold", "margin": "xs" }
              ],
              "backgroundColor": "#f0d8d0", "cornerRadius": "sm", "paddingAll": "4px", "paddingStart": "6px", "paddingEnd": "8px", "flex": 0
            }
          ]
        },
        { "type": "text", "text": "{{text}}", "weight": "bold", "size": "md", "color": "#a08050", "decoration": "line-through", "margin": "md", "wrap": true },
        { "type": "text", "text": "เหลืองานค้าง {{remaining_count}} รายการ", "size": "xs", "color": "#a08050", "margin": "md" }
      ],
      "paddingAll": "16px"
    },
    "footer": {
      "type": "box",
      "layout": "horizontal",
      "spacing": "sm",
      "contents": [
        { "type": "button", "style": "link", "color": "#c45a3a", "action": { "type": "postback", "label": "↶ Undo", "data": "{{undo_postback_data}}" }, "height": "sm", "flex": 1 },
        { "type": "button", "style": "link", "color": "#a08050", "action": { "type": "uri", "label": "ดูทั้งหมด", "uri": "https://liff.line.me/{{liff_id}}?next=%2Fth%2Fdashboard%2Ftodo" }, "height": "sm", "flex": 1 }
      ],
      "paddingAll": "16px"
    }
  }
}