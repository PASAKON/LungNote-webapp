{
  "type": "flex",
  "altText": "งานค้าง {{count}} รายการ",
  "contents": {
    "type": "bubble",
    "size": "giga",
    "header": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "PENDING",
              "size": "xxs",
              "color": "#c9a040",
              "weight": "bold"
            }
          ],
          "backgroundColor": "#f0e4c4",
          "cornerRadius": "sm",
          "paddingAll": "4px",
          "paddingStart": "8px",
          "paddingEnd": "8px",
          "width": "70px"
        },
        {
          "type": "text",
          "text": "📋 งานค้าง {{count}} รายการ",
          "weight": "bold",
          "size": "xl",
          "margin": "md",
          "color": "#3a3020"
        },
        {
          "type": "text",
          "text": "{{date_pretty}}",
          "size": "xs",
          "color": "#a08050",
          "margin": "sm"
        }
      ],
      "paddingAll": "16px",
      "paddingBottom": "12px"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        { "type": "separator", "color": "#d4c4a0" },
        "{{ROWS}}"
      ],
      "paddingAll": "16px",
      "paddingTop": "0px"
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#c9a040",
          "action": { "type": "uri", "label": "เปิด Dashboard", "uri": "{{open_url}}" },
          "height": "md"
        },
        {
          "type": "text",
          "text": "พิมพ์ 'ลบ N' หรือ 'N เสร็จ' ได้เลย",
          "size": "xxs",
          "color": "#a08050",
          "align": "center",
          "margin": "sm"
        }
      ],
      "paddingAll": "16px"
    }
  }
}
