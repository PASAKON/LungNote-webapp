{
  "type": "flex",
  "altText": "งานค้าง {{count}} รายการ",
  "contents": {
    "type": "bubble",
    "size": "giga",
    "header": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "text",
          "text": "งานค้าง {{count}} รายการ",
          "weight": "bold",
          "size": "xl",
          "color": "#3a3020"
        },
        {
          "type": "text",
          "text": "{{date_display}}",
          "size": "xs",
          "color": "#a08050",
          "margin": "sm"
        }
      ],
      "paddingAll": "16px",
      "paddingBottom": "8px"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "separator",
          "color": "#d4c4a0"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "{{items[0].idx}}",
              "size": "xxs",
              "color": "#a08050",
              "flex": 0,
              "gravity": "center"
            },
            {
              "type": "text",
              "text": "{{items[0].text}}",
              "size": "sm",
              "weight": "bold",
              "color": "#3a3020",
              "margin": "md",
              "flex": 5,
              "wrap": true
            },
            {
              "type": "text",
              "text": "{{items[0].due_short}}",
              "size": "xxs",
              "weight": "bold",
              "color": "{{items[0].urgency_color}}",
              "align": "end",
              "flex": 2,
              "gravity": "center"
            }
          ],
          "margin": "lg",
          "paddingBottom": "12px"
        },
        {
          "type": "separator",
          "color": "#d4c4a0"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "{{items[1].idx}}",
              "size": "xxs",
              "color": "#a08050",
              "flex": 0,
              "gravity": "center"
            },
            {
              "type": "text",
              "text": "{{items[1].text}}",
              "size": "sm",
              "weight": "bold",
              "color": "#3a3020",
              "margin": "md",
              "flex": 5,
              "wrap": true
            },
            {
              "type": "text",
              "text": "{{items[1].due_short}}",
              "size": "xxs",
              "weight": "bold",
              "color": "{{items[1].urgency_color}}",
              "align": "end",
              "flex": 2,
              "gravity": "center"
            }
          ],
          "margin": "lg",
          "paddingBottom": "12px"
        },
        {
          "type": "separator",
          "color": "#d4c4a0"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "{{items[2].idx}}",
              "size": "xxs",
              "color": "#a08050",
              "flex": 0,
              "gravity": "center"
            },
            {
              "type": "text",
              "text": "{{items[2].text}}",
              "size": "sm",
              "weight": "bold",
              "color": "#3a3020",
              "margin": "md",
              "flex": 5,
              "wrap": true
            },
            {
              "type": "text",
              "text": "{{items[2].due_short}}",
              "size": "xxs",
              "weight": "bold",
              "color": "{{items[2].urgency_color}}",
              "align": "end",
              "flex": 2,
              "gravity": "center"
            }
          ],
          "margin": "lg",
          "paddingBottom": "12px"
        },
        {
          "type": "separator",
          "color": "#d4c4a0"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "text",
              "text": "{{items[3].idx}}",
              "size": "xxs",
              "color": "#a08050",
              "flex": 0,
              "gravity": "center"
            },
            {
              "type": "text",
              "text": "{{items[3].text}}",
              "size": "sm",
              "weight": "bold",
              "color": "#3a3020",
              "margin": "md",
              "flex": 5,
              "wrap": true
            },
            {
              "type": "text",
              "text": "{{items[3].due_short}}",
              "size": "xxs",
              "weight": "bold",
              "color": "{{items[3].urgency_color}}",
              "align": "end",
              "flex": 2,
              "gravity": "center"
            }
          ],
          "margin": "lg"
        }
      ],
      "paddingAll": "16px",
      "paddingTop": "0px"
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#c9a040",
          "action": {
            "type": "uri",
            "label": "เปิด Dashboard",
            "uri": "{{open_url}}"
          },
          "height": "sm"
        },
        {
          "type": "text",
          "text": "ทำเสร็จ ➡️ ส่งเลขมาบอก",
          "size": "xxs",
          "color": "#a08050",
          "align": "center",
          "margin": "sm"
        }
      ],
      "paddingAll": "16px"
    }
  }
}
