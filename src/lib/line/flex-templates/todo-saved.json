{
  "type": "flex",
  "altText": "บันทึก '{{text}}' แล้ว",
  "contents": {
    "type": "bubble",
    "size": "kilo",
    "header": {
      "type": "box",
      "layout": "horizontal",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            {
              "type": "text",
              "text": "จดสำเร็จ ✅",
              "weight": "bold",
              "size": "lg",
              "color": "#3a3020"
            },
            {
              "type": "text",
              "text": "อย่าลืมตรวจสอบรายการที่จดด้วยนะ",
              "size": "xxs",
              "color": "#a08050",
              "margin": "sm"
            }
          ],
          "flex": 3
        }
      ],
      "paddingAll": "20px",
      "paddingBottom": "12px",
      "background": {
        "type": "linearGradient",
        "angle": "135deg",
        "startColor": "#f0e4c4",
        "endColor": "#faf5e8"
      }
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "📁", "size": "xs", "flex": 0 },
                { "type": "text", "text": "{{folder_name}}", "size": "xxs", "color": "#a07820", "weight": "bold", "margin": "xs" }
              ],
              "backgroundColor": "#f0e4c4",
              "cornerRadius": "sm",
              "paddingAll": "4px",
              "paddingStart": "6px",
              "paddingEnd": "8px",
              "flex": 0
            },
            { "type": "text", "text": "⏰ {{due_text}}", "size": "xxs", "color": "#a08050", "align": "end", "flex": 1 }
          ]
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            { "type": "text", "text": "{{text}}", "weight": "bold", "size": "md", "color": "#3a3020", "flex": 3, "wrap": true },
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                {
                  "type": "button",
                  "action": { "type": "postback", "label": "✏", "data": "action=edit&id={{id}}" },
                  "style": "secondary",
                  "color": "#f0e4c4",
                  "height": "sm",
                  "flex": 0
                },
                {
                  "type": "button",
                  "action": { "type": "postback", "label": "✕", "data": "action=delete&id={{id}}" },
                  "style": "secondary",
                  "color": "#f0d8d0",
                  "height": "sm",
                  "flex": 0
                }
              ],
              "spacing": "xs",
              "flex": 0
            }
          ],
          "margin": "md"
        }
      ],
      "paddingAll": "16px"
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#c9a040",
          "action": {
            "type": "uri",
            "label": "ดูใน Dashboard",
            "uri": "{{open_url}}"
          },
          "height": "sm"
        }
      ],
      "paddingAll": "16px"
    }
  }
}