{
  "type": "flex",
  "altText": "บันทึก '{{text}}' แล้ว",
  "contents": {
    "type": "bubble",
    "size": "kilo",
    "header": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            { "type": "text", "text": "✓", "size": "3xl", "weight": "bold", "color": "#c9a040", "align": "center" }
          ],
          "width": "48px",
          "height": "48px",
          "backgroundColor": "#f0e4c4",
          "cornerRadius": "50px",
          "justifyContent": "center",
          "alignItems": "center",
          "offsetStart": "calc(50% - 24px)"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            { "type": "text", "text": "SAVED", "size": "xxs", "color": "#c9a040", "weight": "bold", "align": "center" }
          ],
          "backgroundColor": "#f0e4c4",
          "cornerRadius": "sm",
          "paddingAll": "4px",
          "paddingStart": "8px",
          "paddingEnd": "8px",
          "width": "56px",
          "margin": "md",
          "offsetStart": "calc(50% - 28px)"
        },
        {
          "type": "text",
          "text": "บันทึกแล้ว",
          "weight": "bold",
          "size": "lg",
          "margin": "md",
          "color": "#3a3020",
          "align": "center"
        }
      ],
      "paddingAll": "16px",
      "paddingTop": "20px"
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        { "type": "separator", "color": "#d4c4a0" },
        {
          "type": "text",
          "text": "{{text}}",
          "size": "md",
          "weight": "bold",
          "color": "#3a3020",
          "wrap": true,
          "margin": "lg"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            { "type": "text", "text": "โฟลเดอร์", "size": "xs", "color": "#a08050", "flex": 3 },
            { "type": "text", "text": "{{folder_name}}", "size": "xs", "weight": "bold", "color": "#3a3020", "align": "end", "flex": 5 }
          ],
          "margin": "md"
        },
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            { "type": "text", "text": "⏰ กำหนด", "size": "xs", "color": "#a08050", "flex": 3 },
            { "type": "text", "text": "{{due_at_pretty}}", "size": "xs", "weight": "bold", "color": "#3a3020", "align": "end", "flex": 5 }
          ],
          "margin": "sm"
        }
      ],
      "paddingAll": "16px",
      "paddingTop": "8px"
    },
    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#c9a040",
          "action": { "type": "uri", "label": "ดูใน Dashboard", "uri": "{{open_url}}" },
          "height": "sm"
        }
      ],
      "paddingAll": "12px"
    }
  }
}
