{
  "type": "flex",
  "altText": "เสร็จ '{{text}}' ✓ — เหลือ {{pending_count_left}} รายการ",
  "contents": {
    "type": "bubble",
    "size": "kilo",
    "header": {
      "type": "box",
      "layout": "horizontal",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            { "type": "text", "text": "เสร็จแล้ว 🎉", "weight": "bold", "size": "lg", "color": "#ffffff" },
            { "type": "text", "text": "เก่งมาก! ทำต่อไปนะ", "size": "xxs", "color": "#ffffff99", "margin": "sm" }
          ],
          "flex": 3
        }
      ],
      "paddingAll": "20px",
      "paddingBottom": "12px",
      "background": { "type": "linearGradient", "angle": "135deg", "startColor": "#7a9a50", "endColor": "#90b060" }
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "contents": [
        {
          "type": "box",
          "layout": "horizontal",
          "contents": [
            {
              "type": "box",
              "layout": "horizontal",
              "contents": [
                { "type": "text", "text": "📁", "size": "xs", "flex": 0 },
                { "type": "text", "text": "{{folder_name}}", "size": "xxs", "color": "#5a7a30", "weight": "bold", "margin": "xs" }
              ],
              "backgroundColor": "#e8f0d8", "cornerRadius": "sm", "paddingAll": "4px", "paddingStart": "6px", "paddingEnd": "8px", "flex": 0
            }
          ]
        },
        { "type": "text", "text": "{{text}}", "weight": "bold", "size": "md", "color": "#a08050", "decoration": "line-through", "margin": "md", "wrap": true },
        { "type": "text", "text": "เหลือ {{pending_count_left}} งาน", "size": "xs", "color": "#a08050", "margin": "md" },
        {
          "type": "box",
          "layout": "vertical",
          "contents": [
            { "type": "text", "text": "{{streak_msg}}", "size": "sm", "weight": "bold", "color": "#c9a040", "align": "center" }
          ],
          "backgroundColor": "#f0e4c4", "cornerRadius": "md", "paddingAll": "10px", "margin": "md"
        }
      ],
      "paddingAll": "16px"
    },
    "footer": {
      "type": "box",
      "layout": "horizontal",
      "spacing": "sm",
      "contents": [
        { "type": "button", "style": "link", "color": "#a08050", "action": { "type": "postback", "label": "↶ Undo", "data": "{{undo_postback_data}}" }, "height": "sm", "flex": 1 },
        { "type": "button", "style": "primary", "color": "#7a9a50", "action": { "type": "uri", "label": "ดูงานที่เหลือ", "uri": "https://liff.line.me/{{liff_id}}?next=%2Fth%2Fdashboard%2Ftodo" }, "height": "sm", "flex": 2 }
      ],
      "paddingAll": "16px"
    }
  }
}