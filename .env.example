# LungNote env template
# Real values live in Vercel project env vars (passgob1-8454s-projects/lungnote-webapp).
# To populate .env.local: ./scripts/pull-env.sh development

# Supabase (see ADR-0006)
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# LINE Official Account — Messaging API (server-only)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE LIFF (in-app webview auth, ADR-0010)
NEXT_PUBLIC_LINE_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=

# OpenRouter LLM gateway — LINE bot AI replies (ADR-0008)
OPENROUTER_API_KEY=
