# LungNote env template
# Real values live in Vercel project env vars (passgob1-8454s-projects/lungnote-webapp).
# To populate .env.local: ./scripts/pull-env.sh development

# Supabase (see ADR-0006)
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# LINE Official Account — Messaging API (server-only)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE LIFF (in-app webview auth, ADR-0010)
NEXT_PUBLIC_LINE_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=

# OpenRouter LLM gateway — LINE bot AI replies (ADR-0008)
OPENROUTER_API_KEY=

# Gmail integration v1 (ADR-0017 / ADR-0018 / ADR-0019)
# Google Cloud Console — OAuth Client (Web), see ADR-0017 §"OAuth Flow"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://lungnote.com/api/auth/gmail/callback

# AES-256-GCM key for refresh_token_enc; generate via:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
GMAIL_ENC_KEY=

# Pub/Sub real-time push (ADR-0017 §"Sync Trigger")
GCP_PROJECT_ID=
GMAIL_PUBSUB_TOPIC=projects/<GCP_PROJECT_ID>/topics/gmail-events
PUBSUB_PUSH_SERVICE_ACCOUNT=
PUBSUB_AUDIENCE=https://lungnote.com/api/gmail/pubsub

# Vercel cron auth — same value as Vercel cron Bearer
CRON_SECRET=
